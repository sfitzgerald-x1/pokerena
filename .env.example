# Optional overrides for local development.
POKERENA_SHOWDOWN_PATH=vendor/pokemon-showdown
POKERENA_BIND_ADDRESS=0.0.0.0
POKERENA_PORT=8000
POKERENA_SERVER_ID=pokerena-local
POKERENA_PUBLIC_ORIGIN=http://localhost:8000
POKERENA_NO_SECURITY=true
POKERENA_DATA_DIR=.runtime/showdown/data
POKERENA_LOG_DIR=.runtime/showdown/logs

